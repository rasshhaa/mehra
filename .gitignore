# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Virtual environments ──────────────────────────────────────────
.venv/
venv/
env/
ENV/
**/.venv/

# ── Editor / OS ───────────────────────────────────────────────────
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Build / packaging artefacts ───────────────────────────────────
build/
dist/
*.egg-info/
*.egg

# ── Runtime-generated PDFs (regenerated by the backend) ───────────
frontend/static/inspection_report.pdf
frontend/static/accident_service_report.pdf
frontend/static/garage_service_report.pdf

# ── Runtime-generated images (annotated/captured frames) ──────────
frontend/static/annotated_*.jpg
frontend/static/annotated_*.png
frontend/static/capture_*.jpg
frontend/static/capture_*.png

# ── Temp upload buckets ───────────────────────────────────────────
backend/uploads/*.jpg
backend/uploads/*.jpeg
backend/uploads/*.png
backend/uploads/*.mp3
backend/uploads/*.wav
backend/uploads/*.m4a
!backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────
*.log
